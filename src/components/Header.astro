---
// Header.astro
import { useTranslations } from '../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  lang: 'en' | 'es' | 'fr';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header class="main-header glass-panel">
  <div class="header-container">
    <!-- Brand Logo -->
    <div class="brand">
      <div class="logo-icons">
        <svg class="icon-foot" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 17h6c1.5 0 2.5-1 3.5-2.5l2-3c.8-1.2 2-1.5 3-1l.5.3c1 .5 1.5 1.7 1 2.7l-1.5 3.5c-.8 1.8-2.5 3-4.5 3H4v-3z" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12 17v2" stroke-linecap="round"/>
          <circle cx="21" cy="7" r="1.5" fill="currentColor"/>
        </svg>
        <span class="logo-vs">VS</span>
        <svg class="icon-head" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 15c.5.5 1.5.5 2 0s.5-1.5 0-2l-3-3c-.5-.5-1.5-.5-2 0l-1 1c.5 1.5.5 3 0 4.5l4-0.5z" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M8 11c1-1.5 2-2 3.5-2.5S15 8 16 9.5s.5 2.5-.5 3.5S12.5 15.5 11 16H8v-5z" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="18" cy="4" r="1.5" fill="currentColor"/>
        </svg>
      </div>
      <div class="logo-text">
        <h1>{t('title')}</h1>
        <p class="tagline">{t('subtitle')}</p>
      </div>
    </div>

    <!-- Navigation Tabs & Language Picker -->
    <div class="nav-controls">
      <!-- Language Picker -->
      <div class="lang-picker">
        <a href={getRelativeLocaleUrl('en', '/')} class={`lang-link ${lang === 'en' ? 'active' : ''}`} aria-label="English">EN</a>
        <span class="divider">|</span>
        <a href={getRelativeLocaleUrl('es', '/')} class={`lang-link ${lang === 'es' ? 'active' : ''}`} aria-label="Español">ES</a>
        <span class="divider">|</span>
        <a href={getRelativeLocaleUrl('fr', '/')} class={`lang-link ${lang === 'fr' ? 'active' : ''}`} aria-label="Français">FR</a>
      </div>

      <nav class="header-nav">
        <div class="nav-tabs">
          <button class="nav-tab active" data-tab="groups" id="tab-groups">
            <span>{t('nav.groups')}</span>
          </button>
          <button class="nav-tab" data-tab="bracket" id="tab-bracket">
            <span>{t('nav.bracket')}</span>
          </button>
          <div class="tab-indicator" id="tab-indicator"></div>
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    border-radius: 0 0 24px 24px;
    border-top: none;
    border-left: none;
    border-right: none;
    background: rgba(10, 12, 22, 0.85);
  }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  /* Logo / Brand */
  .brand {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .logo-icons {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--text-primary);
  }

  .icon-foot {
    width: 28px;
    height: 28px;
    color: var(--color-pieds);
    filter: drop-shadow(0 0 6px var(--color-pieds-glow-strong));
  }

  .icon-head {
    width: 28px;
    height: 28px;
    color: var(--color-tetes);
    filter: drop-shadow(0 0 6px var(--color-tetes-glow-strong));
    transform: scaleX(-1);
  }

  .logo-vs {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
    padding: 2px 4px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .logo-text h1 {
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    background: linear-gradient(90deg, #fff, #94a3b8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .tagline {
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  /* Nav Controls (tabs + picker) */
  .nav-controls {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 20px;
  }

  /* Language Picker */
  .lang-picker {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    background: rgba(0, 0, 0, 0.2);
    padding: 6px 12px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.04);
  }

  .lang-link {
    color: var(--text-secondary);
    transition: all 0.2s ease;
    padding: 2px 4px;
    border-radius: 4px;
  }

  .lang-link.active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.08);
    text-shadow: 0 0 4px rgba(255,255,255,0.4);
  }

  .lang-link:hover:not(.active) {
    color: var(--text-primary);
  }

  .divider {
    color: rgba(255, 255, 255, 0.08);
  }

  /* Navigation Tabs */
  .header-nav {
    display: flex;
  }

  .nav-tabs {
    position: relative;
    display: flex;
    background: rgba(0, 0, 0, 0.25);
    padding: 4px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav-tab {
    position: relative;
    padding: 10px 20px;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    border-radius: 8px;
    z-index: 2;
    transition: color 0.3s ease;
  }

  .nav-tab.active {
    color: var(--text-primary);
  }

  .tab-indicator {
    position: absolute;
    top: 4px;
    bottom: 4px;
    left: 4px;
    width: calc(50% - 4px);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    z-index: 1;
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: inset 0 1px 1px rgba(255,255,255,0.1);
  }

  .nav-tabs:has(#tab-bracket.active) .tab-indicator {
    transform: translateX(100%);
  }

  /* Responsive styling */
  @media (max-width: 768px) {
    .header-container {
      flex-direction: column;
      gap: 12px;
      padding: 12px 16px;
    }
    .brand {
      justify-content: center;
    }
    .nav-controls {
      justify-content: space-between;
      width: 100%;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      padding-top: 12px;
    }
  }

  @media (max-width: 640px) {
    .main-header {
      border-radius: 0 0 16px 16px;
    }
    .nav-controls {
      flex-direction: column;
      gap: 12px;
      padding-top: 8px;
    }
    .lang-picker {
      width: 100%;
      justify-content: center;
    }
    .header-nav {
      justify-content: center;
      width: 100%;
    }
    .nav-tabs {
      width: 100%;
    }
    .nav-tab {
      flex: 1;
      text-align: center;
      padding: 8px 12px;
      font-size: 0.8rem;
    }
  }
</style>
