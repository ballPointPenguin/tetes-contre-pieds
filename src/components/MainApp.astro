---
import '../styles/global.css';
import Header from './Header.astro';
import GroupStage from './GroupStage.astro';
import KnockoutBracket from './KnockoutBracket.astro';
import wcData from '../data/wc2026.json';
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: 'en' | 'es' | 'fr';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const { groups, knockouts } = wcData;

// --- Server-Side Calculations ---

interface StandingRow {
  team: string;
  played: number;
  win: number;
  draw: number;
  loss: number;
  gf: number;
  ga: number;
  gd: number;
  pts: number;
}

const standings: Record<string, StandingRow[]> = {};
let totalPieds = 0;
let totalTetes = 0;
let completedMatches = 0;

groups.forEach(group => {
  const teamMap: Record<string, StandingRow> = {};
  group.teams.forEach(team => {
    teamMap[team] = {
      team,
      played: 0,
      win: 0,
      draw: 0,
      loss: 0,
      gf: 0,
      ga: 0,
      gd: 0,
      pts: 0
    };
  });

  group.matches.forEach(match => {
    const m = match as any;
    if (m.result) {
      const res = m.result;
      totalPieds += res.feetGoals || 0;
      totalTetes += res.headGoals || 0;
      completedMatches++;

      const homeRow = teamMap[match.home];
      const awayRow = teamMap[match.away];

      if (homeRow && awayRow) {
        homeRow.played++;
        awayRow.played++;
        
        homeRow.gf += res.homeScore;
        homeRow.ga += res.awayScore;
        awayRow.gf += res.awayScore;
        awayRow.ga += res.homeScore;

        if (res.homeScore > res.awayScore) {
          homeRow.win++;
          homeRow.pts += 3;
          awayRow.loss++;
        } else if (res.homeScore < res.awayScore) {
          awayRow.win++;
          awayRow.pts += 3;
          homeRow.loss++;
        } else {
          homeRow.draw++;
          awayRow.draw++;
          homeRow.pts += 1;
          awayRow.pts += 1;
        }
      }
    }
  });

  // Calculate goal differences and convert to array
  const rows = Object.values(teamMap).map(row => {
    row.gd = row.gf - row.ga;
    return row;
  });

  // Sort standings: Pts desc, GD desc, Wins desc, Name alphabetical asc
  rows.sort((a, b) => {
    if (b.pts !== a.pts) return b.pts - a.pts;
    if (b.gd !== a.gd) return b.gd - a.gd;
    if (b.win !== a.win) return b.win - a.win;
    return a.team.localeCompare(b.team);
  });

  standings[group.id] = rows;
});
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Tags -->
    <title>{t('title')} - {t('subtitle')}</title>
    <meta name="description" content={t('seo.description')} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={`${t('title')} - ${t('subtitle')}`} />
    <meta property="og:description" content={t('seo.description')} />
    <meta property="og:type" content="website" />
  </head>
  <body data-lang={lang}>
    <!-- Brand Header with pre-calculated scores -->
    <Header lang={lang} totalPieds={totalPieds} totalTetes={totalTetes} completedMatches={completedMatches} />

    <!-- Main View Canvas -->
    <main class="main-content container">
      <!-- Section 1: Group Stage (Active by default) -->
      <section id="view-groups" class="tab-view active">
        <GroupStage groups={groups} standings={standings} lang={lang} />
      </section>

      <!-- Section 2: Knockout Bracket -->
      <section id="view-bracket" class="tab-view">
        <KnockoutBracket knockouts={knockouts} lang={lang} />
      </section>
    </main>

    <!-- Footer -->
    <footer class="app-footer">
      <div class="container footer-content">
        <p>{t('footer.copyright')}</p>
        <p class="footer-note">{t('footer.disclaimer')}</p>
      </div>
    </footer>

    <!-- Client Interactive Layout Logic -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // --- Tab View Switching ---
        const tabGroups = document.getElementById('tab-groups');
        const tabBracket = document.getElementById('tab-bracket');
        const viewGroups = document.getElementById('view-groups');
        const viewBracket = document.getElementById('view-bracket');

        function switchTab(targetTab) {
          if (targetTab === 'groups') {
            tabGroups?.classList.add('active');
            tabBracket?.classList.remove('active');
            viewGroups?.classList.add('active');
            viewBracket?.classList.remove('active');
          } else {
            tabGroups?.classList.remove('active');
            tabBracket?.classList.add('active');
            viewGroups?.classList.remove('active');
            viewBracket?.classList.add('active');
          }
        }

        tabGroups?.addEventListener('click', () => switchTab('groups'));
        tabBracket?.addEventListener('click', () => switchTab('bracket'));

        // --- Mobile Round Column Selector (Knockout Bracket) ---
        const roundButtons = document.querySelectorAll('.round-nav-btn');
        roundButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            const roundId = btn.getAttribute('data-round-tab');
            
            // Highlight selected button
            roundButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            // Show matching column
            const columns = document.querySelectorAll('.bracket-column');
            columns.forEach(col => {
              if (col.getAttribute('data-round-col') === roundId) {
                col.classList.add('active');
              } else {
                col.classList.remove('active');
              }
            });
          });
        });

        // --- Smooth Scroll Offset for Group Anchors ---
        const anchorLinks = document.querySelectorAll('.quick-nav-link');
        anchorLinks.forEach(link => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = link.getAttribute('href');
            if (!targetId) return;
            const targetEl = document.querySelector(targetId);
            if (targetEl) {
              const offset = 140; // offset for sticky header + nav
              const bodyRect = document.body.getBoundingClientRect().top;
              const elementRect = targetEl.getBoundingClientRect().top;
              const elementPosition = elementRect - bodyRect;
              const offsetPosition = elementPosition - offset;

              window.scrollTo({
                top: offsetPosition,
                behavior: 'smooth'
              });
            }
          });
        });
      });
    </script>
  </body>
</html>

<style>
  .main-content {
    margin-top: 140px;
    min-height: 80vh;
    padding-bottom: 60px;
  }

  .tab-view {
    display: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .tab-view.active {
    display: block;
    opacity: 1;
  }

  .app-footer {
    background: rgba(8, 10, 18, 0.95);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 30px 0;
    color: var(--text-muted);
    font-size: 0.8rem;
    text-align: center;
    margin-top: 80px;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-note {
    font-size: 0.75rem;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .main-content {
      margin-top: 190px;
    }
  }

  @media (max-width: 640px) {
    .main-content {
      margin-top: 170px;
    }
    .app-footer {
      padding: 20px 0;
      margin-top: 40px;
    }
  }
</style>
