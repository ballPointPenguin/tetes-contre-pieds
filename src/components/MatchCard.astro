---
// MatchCard.astro
import wcData from '../data/wc2026.json';
import { useTranslations } from '../i18n/ui';

interface MatchResult {
  homeScore: number;
  awayScore: number;
  homeFeetGoals: number;
  homeHeadGoals: number;
  awayFeetGoals: number;
  awayHeadGoals: number;
}

interface Props {
  id: number;
  home: string;
  away: string;
  date: string;
  venue: string;
  isKnockout?: boolean;
  homePlaceholder?: string;
  awayPlaceholder?: string;
  result?: MatchResult;
  lang: 'en' | 'es' | 'fr';
}

const { id, home, away, date, venue, isKnockout = false, homePlaceholder = "", awayPlaceholder = "", result, lang } = Astro.props;
const t = useTranslations(lang);

// Build a map of team name -> type ("pieds" | "tetes") from wcData
const teamTypes: Record<string, 'pieds' | 'tetes'> = {};
wcData.groups.forEach(group => {
  group.teams.forEach((teamName, index) => {
    teamTypes[teamName] = (index % 2 === 0) ? 'pieds' : 'tetes';
  });
});

const homeType = home ? teamTypes[home] : "unknown";
const awayType = away ? teamTypes[away] : "unknown";
---

<div 
  class="match-card glass-panel" 
  data-match-id={id}
  data-home={home}
  data-away={away}
  data-home-placeholder={homePlaceholder}
  data-away-placeholder={awayPlaceholder}
  data-is-knockout={isKnockout ? "true" : "false"}
>
  <!-- Card Header: Match ID, Round, Date/Venue -->
  <div class="match-card-header">
    <span class="match-number">N°{id}</span>
    <span class="match-meta">{date} • {venue}</span>
  </div>

  <!-- Teams Section -->
  <div class="match-teams">
    <!-- Home Team -->
    <div class="team-row" data-team="home">
      <div class="team-badge-wrapper">
        <span class="team-name" data-team-text="home">{home ? t(home as any) : homePlaceholder}</span>
      </div>
      <div class="team-type-badge-container" data-team-badge="home">
        {home && (
          homeType === "pieds" ? (
            <span class="type-badge pieds">
              <span class="badge-icon">🦶</span>
            </span>
          ) : (
            <span class="type-badge tetes">
              <span class="badge-icon">👤</span>
            </span>
          )
        )}
      </div>
    </div>

    <!-- VS Divider -->
    <div class="match-vs-divider">
      <span class="vs-line"></span>
      {result ? (
        <span class="score-text font-display">{result.homeScore} - {result.awayScore}</span>
      ) : (
        <span class="vs-text">VS</span>
      )}
      <span class="vs-line"></span>
    </div>

    <!-- Away Team -->
    <div class="team-row" data-team="away">
      <div class="team-badge-wrapper">
        <span class="team-name" data-team-text="away">{away ? t(away as any) : awayPlaceholder}</span>
      </div>
      <div class="team-type-badge-container" data-team-badge="away">
        {away && (
          awayType === "pieds" ? (
            <span class="type-badge pieds">
              <span class="badge-icon">🦶</span>
            </span>
          ) : (
            <span class="type-badge tetes">
              <span class="badge-icon">👤</span>
            </span>
          )
        )}
      </div>
    </div>
  </div>

  <!-- Têtes-Pieds Breakdown Footer -->
  {result && (
    <div class="match-breakdown-footer">
      <div class="breakdown-content">
        <span class="breakdown-label">Têtes-Pieds</span>
        <div class="breakdown-goals">
          <span class="goal-stat pieds">🦶 {(result.homeFeetGoals || 0) + (result.awayFeetGoals || 0)}</span>
          <span class="goal-stat-separator">-</span>
          <span class="goal-stat tetes">{(result.homeHeadGoals || 0) + (result.awayHeadGoals || 0)} 👤</span>
        </div>
      </div>
    </div>
  )}
</div>

<style>
  .match-card {
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: hidden;
    background: rgba(18, 22, 43, 0.4);
    transition: border-color 0.3s ease;
  }

  /* Card Header styling */
  .match-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    padding-bottom: 6px;
  }

  .match-number {
    font-family: var(--font-display);
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.05);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 0.7rem;
  }

  .match-meta {
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 170px;
  }

  /* Teams list */
  .match-teams {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .team-row {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 10px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(255, 255, 255, 0.02);
  }

  .team-badge-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .team-name {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .type-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .type-badge.pieds {
    background: rgba(0, 242, 254, 0.1);
    color: var(--color-pieds);
    border: 1px solid rgba(0, 242, 254, 0.2);
  }

  .type-badge.tetes {
    background: rgba(255, 0, 127, 0.1);
    color: var(--color-tetes);
    border: 1px solid rgba(255, 0, 127, 0.2);
  }

  /* VS separator style */
  .match-vs-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    height: 24px;
  }

  .vs-line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.05);
  }

  .vs-text {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 800;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .score-text {
    font-size: 0.95rem;
    font-weight: 800;
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    padding: 3px 8px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    min-width: 50px;
    text-align: center;
    letter-spacing: 0.05em;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .match-breakdown-footer {
    margin-top: 4px;
    padding-top: 8px;
    border-top: 1px dashed rgba(255, 255, 255, 0.06);
  }

  .breakdown-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.7rem;
    font-family: var(--font-display);
    font-weight: 600;
  }

  .breakdown-label {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .breakdown-goals {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .goal-stat.pieds {
    color: var(--color-pieds);
    text-shadow: 0 0 6px var(--color-pieds-glow);
  }

  .goal-stat.tetes {
    color: var(--color-tetes);
    text-shadow: 0 0 6px var(--color-tetes-glow);
  }

  .goal-stat-separator {
    color: var(--text-muted);
  }
</style>
